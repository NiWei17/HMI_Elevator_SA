<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.EventHandler">
   <Button layoutX="450.0" layoutY="106.0" mnemonicParsing="false" onAction="#onResetClicked" prefHeight="26.0"
           prefWidth="75.0" text="Reset"/>
   <Button layoutX="262.0" layoutY="107.0" mnemonicParsing="false" onAction="#onCloseDoorClicked" text="Close Door"/>
   <Button layoutX="91.0" layoutY="107.0" mnemonicParsing="false" onAction="#onOpenDoorClicked" text="Open Door"/>
   <Label alignment="CENTER" contentDisplay="CENTER" layoutX="195.0" layoutY="33.0" prefHeight="65.0" prefWidth="209.0"
          text="Elevator HMI">
      <font>
         <Font name="System Bold" size="22.0"/>
      </font>
   </Label>
   <Label alignment="CENTER" contentDisplay="CENTER" layoutX="90.0" layoutY="219.0" prefHeight="26.0" prefWidth="98.0"
          text="Door State">
      <font>
         <Font name="System Bold" size="16.0"/>
      </font>
   </Label>
   <Label alignment="CENTER" contentDisplay="CENTER" layoutX="90.0" layoutY="308.0" prefHeight="26.0" prefWidth="97.0"
          text="Motor State">
      <font>
         <Font name="System Bold" size="16.0"/>
      </font>
   </Label>
   <Label alignment="CENTER" contentDisplay="CENTER" layoutX="262.0" layoutY="193.0" prefHeight="26.0" prefWidth="75.0"
          text="Door Opened"/>
   <Label alignment="CENTER" contentDisplay="CENTER" layoutX="450.0" layoutY="193.0" prefHeight="26.0" prefWidth="75.0"
          text="Door Closed"/>
   <Label alignment="CENTER" contentDisplay="CENTER" layoutX="262.0" layoutY="282.0" prefHeight="26.0" prefWidth="75.0"
          text="Motor Ready"/>
   <Label alignment="CENTER" contentDisplay="CENTER" layoutX="450.0" layoutY="282.0" prefHeight="26.0" prefWidth="75.0"
          text="Motor On"/>
   <Circle id="doorStateOpened" fill="#ff1f1f" layoutX="300.0" layoutY="241.0" radius="22.0" stroke="BLACK"
           strokeType="INSIDE"/>
   <Circle id="doorStateClosed" fill="#ff261f" layoutX="488.0" layoutY="241.0" radius="22.0" stroke="BLACK"
           strokeType="INSIDE"/>
   <Circle id="motorStateReady" fill="#ff1f1f" layoutX="300.0" layoutY="330.0" radius="22.0" stroke="BLACK"
           strokeType="INSIDE"/>
   <Circle id="motorStateOn" fill="#ff1f1f" layoutX="488.0" layoutY="330.0" radius="22.0" stroke="BLACK"
           strokeType="INSIDE"/>
</AnchorPane>
